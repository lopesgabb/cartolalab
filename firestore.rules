rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Dados de rodadas: leitura pública, escrita bloqueada (apenas via Admin SDK / API routes)
    match /rodadas/{round}/{document=**} {
      allow read: if true;
      allow write: if false; // Re-lock after sync
    }

    // Dados agregados do sistema (CQRS): leitura pública, escrita bloqueada
    match /system/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Bloqueia tudo que não for explicitamente permitido
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
