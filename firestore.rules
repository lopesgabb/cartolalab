rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Dados de rodadas: leitura pública, escrita bloqueada (apenas via Admin SDK / API routes)
    match /rodadas/{rodadaId} {
      allow read: if true;
      allow write: if false;

      match /{subcollection}/{docId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Bloqueia tudo que não for rodadas
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
